@{
    ViewData["Title"] = "Home";
}

<style>
    .hero-section {
        background: linear-gradient(135deg, #111827, #1f2937);
        color: white;
        padding: 80px 40px;
        border-radius: 20px;
        text-align: center;
        box-shadow: 0 10px 30px rgba(0,0,0,0.15);
    }

    .hero-title {
        font-size: 48px;
        font-weight: 700;
        margin-bottom: 15px;
    }

    .hero-subtitle {
        font-size: 18px;
        color: #d1d5db;
        margin-bottom: 30px;
    }

    .btn-rounded {
        border-radius: 25px;
        padding: 10px 25px;
        font-size: 16px;
    }

    .feature-card {
        background: white;
        padding: 25px;
        border-radius: 15px;
        box-shadow: 0 8px 20px rgba(0,0,0,0.08);
        text-align: center;
        transition: 0.2s;
    }

        .feature-card:hover {
            transform: translateY(-5px);
        }
</style>

<div class="container mt-5">

    <div class="hero-section">
        <h1 class="hero-title">🎬 Cinema Fan Shop</h1>
        <p class="hero-subtitle">
            Discover movie merchandise, collectibles and exclusive cinema products.
        </p>

        <a asp-controller="Product" asp-action="Index" class="btn btn-light btn-rounded">
            Browse Products
        </a>
    </div>

    <div class="row mt-5 g-4 justify-content-center">

        <div class="col-md-5 col-lg-4">
            <div class="feature-card">
                <h4>🛍 Products</h4>
                <p>Explore movie themed merchandise and collectibles.</p>
                <a asp-controller="Product" asp-action="Index" class="btn btn-dark btn-rounded">View</a>
            </div>
        </div>

          @if (User.Identity.IsAuthenticated && User.IsInRole("Administrator"))
          {
        <div class="col-md-5 col-lg-4">
            <div class="feature-card">
                <h4>📦 Orders</h4>
                <p>Manage and track customer orders easily.</p>
                <a asp-controller="Order" asp-action="Index" class="btn btn-dark btn-rounded">View</a>
            </div>
        </div>
          }

    </div>
