@model IEnumerable<CinemaFanShop.Models.Order.OrderIndexVM>
@{
    ViewData["Title"] = "Orders";
}

<style>
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 25px;
    }

    .modern-card {
        background: white;
        padding: 25px;
        border-radius: 15px;
        box-shadow: 0 8px 20px rgba(0,0,0,0.08);
    }

    .modern-table thead {
        background: #111827;
        color: white;
    }

    .modern-table tbody tr:hover {
        background-color: #f3f4f6;
        transition: 0.2s;
    }

    .product-img {
        width: 80px;
        height: 80px;
        object-fit: cover;
        border-radius: 10px;
    }

    .filter-box {
        background: #f9fafb;
        padding: 15px;
        border-radius: 12px;
        margin-bottom: 20px;
    }

    .btn-rounded {
        border-radius: 20px;
        padding: 5px 15px;
        font-size: 14px;
    }
</style>

<div class="container mt-4">

    <div class="page-header">
        <h2 class="fw-bold">🧾 Orders Dashboard</h2>
    </div>

    <div class="modern-card">

        <table class="table modern-table align-middle">

            <thead>
                <tr>
                    <th>@Html.DisplayNameFor(model => model.OrderDate)</th>
                    <th>@Html.DisplayNameFor(model => model.User)</th>
                    <th>@Html.DisplayNameFor(model => model.Product)</th>
                    <th>Image</th>
                    <th>@Html.DisplayNameFor(model => model.Quantity)</th>
                    <th>@Html.DisplayNameFor(model => model.Price)</th>
                    <th>@Html.DisplayNameFor(model => model.Discount)</th>
                    <th>@Html.DisplayNameFor(model => model.TotalPrice)</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>

                        <td>
                            @item.OrderDate
                        </td>

                        <td>
                            <strong>@item.User</strong>
                        </td>

                        <td>
                            @item.Product
                        </td>

                        <td>
                            <img src="@item.Picture" class="product-img" />
                        </td>

                        <td>
                            @item.Quantity
                        </td>

                        <td>
                            <span class="fw-bold text-success">@item.Price</span>
                        </td>

                        <td>
                            <span class="text-danger">@item.Discount %</span>
                        </td>

                        <td>
                            <span class="fw-bold">@item.TotalPrice</span>
                        </td>

                    </tr>
                }
            </tbody>

        </table>

    </div>

</div>