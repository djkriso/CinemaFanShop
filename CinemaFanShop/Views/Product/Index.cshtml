@model IEnumerable<CinemaFanShop.Models.Product.ProductIndexVM>
@{
    ViewData["Title"] = "Products";
}

<style>
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 25px;
    }

    .modern-card {
        background: white;
        padding: 25px;
        border-radius: 15px;
        box-shadow: 0 8px 20px rgba(0,0,0,0.08);
    }

    .modern-table thead {
        background: #111827;
        color: white;
    }

    .modern-table tbody tr:hover {
        background-color: #f3f4f6;
        transition: 0.2s;
    }

    .product-img {
        width: 80px;
        height: 80px;
        object-fit: cover;
        border-radius: 10px;
    }

    .filter-box {
        background: #f9fafb;
        padding: 15px;
        border-radius: 12px;
        margin-bottom: 20px;
    }

    .btn-rounded {
        border-radius: 20px;
        padding: 5px 15px;
        font-size: 14px;
    }

    /* ❤️ FAVORITES BUTTON */
    .btn-favorite {
        border-radius: 20px;
        padding: 5px 15px;
        font-size: 14px;
        background: linear-gradient(135deg, #ff4d6d, #e11d48);
        color: white;
        border: none;
        transition: 0.25s ease;
    }

    .btn-favorite:hover {
        background: linear-gradient(135deg, #e11d48, #be123c);
        transform: translateY(-1px);
        box-shadow: 0 4px 10px rgba(225,29,72,0.3);
    }

    /* ❤️ FAVORITE BADGE (като бутон) */
    .favorite-badge {
        border-radius: 20px;
        padding: 5px 15px;
        font-size: 14px;
        background: #ffe4e6;
        color: #be123c;
        font-weight: 500;
        display: inline-flex;
        align-items: center;
        gap: 5px;
    }
</style>

<div class="container mt-4">

    <div class="page-header">
        <h2 class="fw-bold">🎬 Products Dashboard</h2>

        @if (User.Identity.IsAuthenticated && User.IsInRole("Administrator"))
        {
            <a asp-action="Create" class="btn btn-primary btn-rounded">+ Create New</a>
        }
    </div>

    <div class="modern-card">

        <form asp-controller="Product" asp-action="Index" method="get" class="filter-box row g-3">
            <div class="col-md-4">
                <input type="text" name="SearchStringBrandName" class="form-control" placeholder="Search by Brand..." />
            </div>
            <div class="col-md-4">
                <input type="text" name="SearchStringMovieName" class="form-control" placeholder="Search by Movie..." />
            </div>
            <div class="col-md-4">
                <input type="text" name="SearchStringCategoryName" class="form-control" placeholder="Search by Category..." />
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-dark w-100 btn-rounded">Filter</button>
            </div>
        </form>

        <table class="table modern-table align-middle">
            <thead>
                <tr>
                    <th>@Html.DisplayNameFor(model => model.ProductName)</th>
                    <th>@Html.DisplayNameFor(model => model.BrandName)</th>
                    <th>@Html.DisplayNameFor(model => model.MovieName)</th>
                    <th>@Html.DisplayNameFor(model => model.CategoryName)</th>
                    <th>Image</th>
                    <th>@Html.DisplayNameFor(model => model.Description)</th>
                    <th>@Html.DisplayNameFor(model => model.Quantity)</th>
                    <th>@Html.DisplayNameFor(model => model.Price)</th>
                    <th>@Html.DisplayNameFor(model => model.Discount)</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td><strong>@item.ProductName</strong></td>
                        <td>@item.BrandName</td>
                        <td>@item.MovieName</td>
                        <td>@item.CategoryName</td>

                        <td>
                            <img src="@item.Picture" class="product-img" />
                        </td>

                        <td>@item.Description</td>
                        <td>@item.Quantity</td>

                        <td>
                            <span class="fw-bold text-success">@item.Price</span>
                        </td>

                        <td>
                            <span class="text-danger">@item.Discount %</span>
                        </td>

                        <td>
                            <div class="d-flex flex-wrap gap-2 align-items-center">

                                <a asp-controller="Order" asp-action="Create" asp-route-id="@item.Id"
                                   class="btn btn-dark btn-sm btn-rounded">Order</a>

                                <a asp-action="Details" asp-route-id="@item.Id"
                                   class="btn btn-success btn-sm btn-rounded">Details</a>

                                @if (User.Identity.IsAuthenticated && User.IsInRole("Administrator"))
                                {
                                    <a asp-action="Edit" asp-route-id="@item.Id"
                                       class="btn btn-warning btn-sm btn-rounded">Edit</a>

                                    <a asp-action="Delete" asp-route-id="@item.Id"
                                       class="btn btn-danger btn-sm btn-rounded">Delete</a>
                                }

                                @if (!item.IsFavorites)
                                {
                                    <form asp-controller="Favorites" asp-action="Add" method="post" class="d-inline">
                                        <input type="hidden" name="productId" value="@item.Id" />
                                        <button type="submit" class="btn btn-favorite btn-sm">
                                            <i class="bi bi-heart"></i> Favorite
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <span class="favorite-badge">
                                        <i class="bi bi-heart-fill"></i> In Favorites
                                    </span>
                                }

                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}