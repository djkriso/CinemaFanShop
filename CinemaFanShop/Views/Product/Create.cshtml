@model CinemaFanShop.Models.Product.ProductCreateVM

@{
    ViewData["Title"] = "Create Product";
}

<style>

    .page-header {
        margin-bottom: 25px;
    }

    .modern-card {
        background: white;
        padding: 30px;
        border-radius: 16px;
        box-shadow: 0 8px 20px rgba(0,0,0,0.08);
        max-width: 700px;
    }

    .btn-rounded {
        border-radius: 20px;
        padding: 6px 18px;
        font-size: 14px;
    }

</style>

<div class="container mt-4">

    <div class="page-header">
        <h2 class="fw-bold">➕ Create Product</h2>
    </div>

    <div class="modern-card">

        <form asp-action="Create">

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="ProductName" class="form-label"></label>
                <input asp-for="ProductName" class="form-control" />
                <span asp-validation-for="ProductName" class="text-danger"></span>
            </div>

            <div class="row">

                <div class="col-md-4 mb-3">
                    <label asp-for="BrandId" class="form-label"></label>
                    <select asp-for="BrandId" class="form-select">
                        @foreach (var brand in Model.Brands)
                        {
                            <option value="@brand.Id">@brand.Name</option>
                        }
                    </select>
                    <span asp-validation-for="BrandId" class="text-danger"></span>
                </div>

                <div class="col-md-4 mb-3">
                    <label asp-for="CategoryId" class="form-label"></label>
                    <select asp-for="CategoryId" class="form-select">
                        @foreach (var category in Model.Categories)
                        {
                            <option value="@category.Id">@category.Name</option>
                        }
                    </select>
                    <span asp-validation-for="CategoryId" class="text-danger"></span>
                </div>

                <div class="col-md-4 mb-3">
                    <label asp-for="MovieId" class="form-label"></label>
                    <select asp-for="MovieId" class="form-select">
                        @foreach (var movie in Model.Movies)
                        {
                            <option value="@movie.Id">@movie.Name</option>
                        }
                    </select>
                    <span asp-validation-for="MovieId" class="text-danger"></span>
                </div>

            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label"></label>
                <input asp-for="Description" class="form-control" />
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Picture" class="form-label"></label>
                <input asp-for="Picture" class="form-control" />
                <span asp-validation-for="Picture" class="text-danger"></span>
            </div>

            <div class="row">

                <div class="col-md-4 mb-3">
                    <label asp-for="Quantity" class="form-label"></label>
                    <input asp-for="Quantity" class="form-control" />
                    <span asp-validation-for="Quantity" class="text-danger"></span>
                </div>

                <div class="col-md-4 mb-3">
                    <label asp-for="Price" class="form-label"></label>
                    <input asp-for="Price" class="form-control" />
                    <span asp-validation-for="Price" class="text-danger"></span>
                </div>

                <div class="col-md-4 mb-3">
                    <label asp-for="Discount" class="form-label"></label>
                    <input asp-for="Discount" class="form-control" />
                    <span asp-validation-for="Discount" class="text-danger"></span>
                </div>

            </div>

            <div class="d-flex gap-2 mt-3">

                <input type="submit"
                       value="Create"
                       class="btn btn-success btn-rounded" />

                <a asp-action="Index"
                   class="btn btn-dark btn-rounded">
                    Back to Products
                </a>

            </div>

        </form>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}