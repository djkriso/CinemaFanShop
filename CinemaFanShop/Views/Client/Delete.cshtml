@model CinemaFanShop.Models.Client.ClientDeleteVM

@{
    ViewData["Title"] = "Delete Client";
}

<style>

    .page-header{
        margin-bottom:25px;
    }

    .modern-card{
        background:white;
        padding:30px;
        border-radius:16px;
        box-shadow:0 8px 20px rgba(0,0,0,0.08);
        max-width:750px;
    }

    .btn-rounded{
        border-radius:20px;
        padding:6px 18px;
        font-size:14px;
    }

</style>

<div class="container mt-4">

    <div class="page-header">
        <h2 class="fw-bold text-danger">🗑 Delete Client</h2>
        <p class="text-muted">Are you sure you want to delete this client?</p>
    </div>

    <div class="modern-card">

        <dl class="row">

            <dt class="col-sm-4">Username</dt>
            <dd class="col-sm-8">@Model.UserName</dd>

            <dt class="col-sm-4">First Name</dt>
            <dd class="col-sm-8">@Model.FirstName</dd>

            <dt class="col-sm-4">Last Name</dt>
            <dd class="col-sm-8">@Model.LastName</dd>

            <dt class="col-sm-4">Address</dt>
            <dd class="col-sm-8">@Model.Address</dd>

            <dt class="col-sm-4">Email</dt>
            <dd class="col-sm-8">@Model.Email</dd>

        </dl>

        <hr class="my-4"/>

        <form asp-action="Delete">

            <input type="hidden" asp-for="Id" />

            <div class="d-flex gap-2">

                <input type="submit"
                       value="Delete"
                       class="btn btn-danger btn-rounded"/>

                <a asp-action="Index"
                   class="btn btn-dark btn-rounded">
                    Back to Clients
                </a>

            </div>

        </form>

    </div>

</div>